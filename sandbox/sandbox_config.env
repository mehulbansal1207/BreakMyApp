# =========================================================================
# sandbox_config.env — Centralized sandbox resource limits
#
# Sourced by docker-compose.sandbox.yml and verify_sandbox.sh to ensure
# the limits tested are exactly the limits deployed.
#
# This file contains NO secrets — only resource caps. Safe to commit.
# =========================================================================

# Memory hard cap (no swap — memswap_limit equals mem_limit)
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_MEMORY_SWAP=512m

# CPU hard cap
SANDBOX_CPU_LIMIT=1.0

# PID limit (prevents fork bombs)
SANDBOX_PID_LIMIT=256

# Tmpfs size caps (writable areas on read-only root fs)
SANDBOX_TMP_SIZE=256M
SANDBOX_VAR_TMP_SIZE=64M
SANDBOX_WORKSPACE_SIZE=512M

# Wall-clock timeout (seconds) — enforced by SIGKILL from orchestration layer
SANDBOX_TIMEOUT_SECONDS=300

# Docker runtime
SANDBOX_RUNTIME=runsc

# Network name (internal, no outbound internet)
SANDBOX_NETWORK=sandbox-net

# Scan timeout passed into the container as env var
SCAN_TIMEOUT=300
